{
  "name": "@estatecompass/api",
  "version": "0.0.1",
  "private": true,
  "description": "EstateCompass API — multi-tenant Fastify server. Per ADR-002: tenant context binding on every request.",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests/integration",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@estatecompass/db": "workspace:*",
    "@estatecompass/kms": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.2.0",
    "@fastify/sensible": "^5.5.0",
    "argon2": "^0.40.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
