# EstateCompass Demo MVP — environment template
# COPY to .env and fill values. Do NOT commit .env (see .gitignore).

# Anthropic API key for Claude (Sage extractor)
ANTHROPIC_API_KEY=

# Postgres (matches docker-compose.yml defaults — change if you re-deploy)
DATABASE_URL=postgres://estatecompass:dev_only_synthetic_data@localhost:5432/estatecompass

# Service URLs (internal Docker network defaults)
API_URL=http://localhost:3000
AI_EXTRACT_URL=http://localhost:8000
CALC_ENGINE_URL=http://localhost:8001
WEB_URL=http://localhost:5173

# KMS mode for v0 — `local-substitute` = file-backed pseudo-KMS for synthetic data only.
# DO NOT use in production. Switch to a real KMS when production_surface=true.
KMS_MODE=local-substitute

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

# Synthetic data seed — used to seed Postgres on first startup
SEED_TENANTS=acme-ria,bedrock-wealth
SEED_HOUSEHOLDS_PER_TENANT=3
